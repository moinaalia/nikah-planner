{
  "dart.flutterSdkPath": "C:\\src\\flutter",
  "dart.lineLength": 100,
  "editor.formatOnSave": true,
  "editor.tabSize": 2,
  "files.associations": {
    "*.dart": "dart"
  },
  "[dart]": {
    "editor.defaultFormatter": "Dart-Code.dart-code",
    "editor.selectionHighlight": false,
    "editor.suggestSelection": "first",
    "editor.wordBasedSuggestions": "off"
  },
  "search.exclude": {
    "**/.dart_tool": true,
    "**/build": true,
    "**/node_modules": true
  }
}
